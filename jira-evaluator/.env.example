# Jira Ticket Evaluator Environment Variables
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# ── Jira Configuration ─────────────────────────────────────────────────────────
# Your Atlassian account email
JIRA_EMAIL=your-email@gmail.com

# Jira API token (generate at: https://id.atlassian.net/manage-profile/security/api-tokens)
JIRA_API_TOKEN=your-jira-api-token

# Your Jira domain (the subdomain of .atlassian.net)
# e.g. if your Jira URL is https://bhaveshkhatri1357.atlassian.net, set: bhaveshkhatri1357
JIRA_DOMAIN=your-domain

# ── GitHub Configuration ───────────────────────────────────────────────────────
# GitHub Personal Access Token with repo read access
# Generate at: https://github.com/settings/tokens → "Fine-grained tokens" or classic
GITHUB_TOKEN=your-github-token

# ── AI Configuration ───────────────────────────────────────────────────────────
# Google Gemini API key
# Generate at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Server Configuration ───────────────────────────────────────────────────────
PORT=3001
